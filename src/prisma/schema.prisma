generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ============ IDENTITY & TENANCY ============

model Cooperative {
  id                   String   @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  NIB                  String?  @unique
  SKAHU                String?  @unique
  status               String   @default("draft") // draft|verified
  modalSimpananPokok   Float    @default(0)
  modalSimpananWajib   Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members              Member[]
  users                User[]
  products             Product[]
  suppliers            Supplier[]
  purchases            Purchase[]
  sales                Sale[]
  warehouses           Warehouse[]
  vehicles             Vehicle[]
  drivers              Driver[]
  outlets              Outlet[]
  profile              CooperativeProfile?
  documents            LegalDocument[]
  villagePotentials    VillagePotential[]
  financingRequests    FinancingRequest[]
  articles             Article[]
  notifications        Notification[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    // admin|operator|ba|pmo
  cooperativeId String?
  deviceId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  cooperative   Cooperative? @relation(fields: [cooperativeId], references: [id])
  devices       Device[]
  officers      SavingsMutation[] @relation("Officer")
  loanOfficers  LoanPayment[] @relation("LoanOfficer")
  approvedLoans Loan[] @relation("ApprovedBy")
  activities    ActivityLog[]
  resolvedConflicts ConflictCase[] @relation("ResolvedBy")
  stockOpnames  StockOpname[]
  notifications Notification[]
}

model Member {
  id            String    @id @default(cuid())
  cooperativeId String
  memberNumber  String
  nik           String    @unique
  name          String
  phone         String?
  address       String?
  status        String    @default("active") // active|inactive
  joinDate      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id])
  savingsAccounts SavingsAccount[]
  loans          Loan[]
  deposits       Deposit[]

  @@index([cooperativeId, deletedAt])
}

model Device {
  id        String    @id @default(cuid())
  userId    String
  deviceId  String    @unique // UUID
  platform  String?
  lastSeenAt DateTime @default(now())
  createdAt DateTime  @default(now())

  user      User @relation(fields: [userId], references: [id])
}

// ============ SIMPAN PINJAM ============

model SavingsAccount {
  id        String    @id @default(cuid())
  memberId  String
  type      String    // pokok|wajib|sukarela
  openedAt  DateTime  @default(now())
  status    String    @default("active") // active|closed
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  member    Member @relation(fields: [memberId], references: [id])
  mutations SavingsMutation[]

  @@index([memberId, status])
}

model SavingsMutation {
  id             String   @id @default(cuid())
  savingsAccountId String
  type           String   // deposit|withdrawal
  amount         Float
  receiptNumber  String   // unique per cooperative
  description    String?
  officerId      String?
  transactionDate DateTime @default(now())
  createdAt      DateTime @default(now())

  account        SavingsAccount @relation(fields: [savingsAccountId], references: [id])
  officer        User? @relation("Officer", fields: [officerId], references: [id])

  // No updatedAt - append only ledger
  @@index([savingsAccountId, transactionDate])
}

model Loan {
  id              String    @id @default(cuid())
  memberId        String
  principal       Float
  interestRate    Float
  tenorMonths     Int
  disbursementDate DateTime?
  status          String    @default("draft") // draft|pending|approved|rejected|active|completed|overdue
  approvedBy      String?
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  member          Member @relation(fields: [memberId], references: [id])
  approvedByUser  User? @relation("ApprovedBy", fields: [approvedBy], references: [id])
  installments    InstallmentSchedule[]

  @@index([memberId, status])
}

model InstallmentSchedule {
  id              String   @id @default(cuid())
  loanId          String
  installmentNumber Int
  dueDate         DateTime
  amountDue       Float
  amountPaid      Float    @default(0)
  status          String   @default("unpaid") // unpaid|paid|late
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  loan            Loan @relation(fields: [loanId], references: [id])
  payments        LoanPayment[]

  @@index([loanId, installmentNumber])
}

model LoanPayment {
  id                   String   @id @default(cuid())
  installmentScheduleId String
  amount               Float
  paymentDate          DateTime @default(now())
  officerId            String?
  receiptNumber        String
  createdAt            DateTime @default(now())

  installment          InstallmentSchedule @relation(fields: [installmentScheduleId], references: [id])
  officer              User? @relation("LoanOfficer", fields: [officerId], references: [id])

  // No updatedAt - append only ledger
  @@index([installmentScheduleId, paymentDate])
}

model Deposit {
  id           String    @id @default(cuid())
  memberId     String
  principal    Float
  tenorMonths  Int
  interestRate Float
  startDate    DateTime  @default(now())
  maturityDate DateTime
  status       String    @default("active") // active|matured|withdrawn
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  member       Member @relation(fields: [memberId], references: [id])

  @@index([memberId, status])
}

// ============ POS & INVENTORY ============

model Product {
  id            String    @id @default(cuid())
  cooperativeId String
  category      String?
  name          String
  unit          String?
  purchasePrice Float?
  salePrice     Float?
  barcode       String?   @unique
  minimumStock  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id])
  stocks        Stock[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  warehouseMutations WarehouseMutation[]
  goodsReceipts GoodsReceipt[]
  deliveryItems DeliveryItem[]

  @@index([cooperativeId, deletedAt])
}

model Supplier {
  id            String    @id @default(cuid())
  cooperativeId String
  name          String
  contact       String?
  address       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id])
  purchases     Purchase[]

  @@index([cooperativeId, deletedAt])
}

model Stock {
  id        String   @id @default(cuid())
  productId String
  location  String?
  quantity  Float    @default(0)
  lastUpdated DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Purchase {
  id            String   @id @default(cuid())
  cooperativeId String
  supplierId    String
  date          DateTime @default(now())
  totalAmount   Float
  paymentStatus String   @default("unpaid") // unpaid|partial|paid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Float
  unitPrice  Float
  subtotal   Float

  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product @relation(fields: [productId], references: [id])
}

model Sale {
  id            String   @id @default(cuid())
  cooperativeId String
  cashierId     String
  date          DateTime @default(now())
  totalAmount   Float
  paymentMethod String   @default("cash") // cash|card|transfer
  status        String   @default("completed") // completed|synced|flagged|resolved
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
  items        SaleItem[]
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Float
  unitPrice Float
  subtotal  Float

  sale      Sale @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

// ============ GUDANG (WAREHOUSE) ============

model Warehouse {
  id            String    @id @default(cuid())
  cooperativeId String
  name          String
  location      String?
  capacity      Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
  racks         RackLocation[]
  goodsReceipts GoodsReceipt[]
  stockOpnames  StockOpname[]
  mutations     WarehouseMutation[]

  @@index([cooperativeId, deletedAt])
}

model RackLocation {
  id         String @id @default(cuid())
  warehouseId String
  rackCode   String
  capacity   Float?

  warehouse  Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, rackCode])
}

model GoodsReceipt {
  id          String    @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Float
  photoUrl    String?
  receiptDate DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  product     Product @relation(fields: [productId], references: [id])
}

model WarehouseMutation {
  id                     String   @id @default(cuid())
  productId              String
  warehouseId            String
  type                   String   // in|out|transfer
  destinationWarehouseId String?
  quantity               Float
  mutationDate           DateTime @default(now())
  referenceNumber        String
  createdAt              DateTime @default(now())

  product                Product @relation(fields: [productId], references: [id])
  warehouse              Warehouse @relation(fields: [warehouseId], references: [id])

  // No updatedAt - append only ledger
  @@index([warehouseId, mutationDate])
}

model StockOpname {
  id          String   @id @default(cuid())
  warehouseId String
  date        DateTime @default(now())
  officerId   String
  status      String   @default("draft") // draft|pending_review|approved|rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  officer     User @relation(fields: [officerId], references: [id])
  items       StockOpnameItem[]
}

model StockOpnameItem {
  id               String  @id @default(cuid())
  stockOpnameId    String
  productId        String
  systemQuantity   Float
  physicalQuantity Float
  difference       Float

  stockOpname      StockOpname @relation(fields: [stockOpnameId], references: [id])
}

// ============ LOGISTIK ============

model Vehicle {
  id           String    @id @default(cuid())
  cooperativeId String
  plateNumber  String    @unique
  type         String?
  capacityKg   Float?
  status       String    @default("active") // active|maintenance|inactive
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
  schedules    DeliverySchedule[]

  @@index([cooperativeId, deletedAt])
}

model Driver {
  id            String    @id @default(cuid())
  cooperativeId String
  name          String
  licenseNumber String    @unique
  phone         String?
  status        String    @default("active") // active|inactive
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
  schedules    DeliverySchedule[]

  @@index([cooperativeId, deletedAt])
}

model DeliverySchedule {
  id        String   @id @default(cuid())
  vehicleId String
  driverId  String
  date      DateTime @default(now())
  origin    String?
  destination String?
  status    String   @default("draft") // draft|scheduled|needs_reschedule|in_progress|delivered_pending_sync|delivered
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  driver    Driver @relation(fields: [driverId], references: [id])
  items     DeliveryItem[]
  appointments Appointment[]
  positions  TrackingPosition[]
  proof      ProofOfDelivery?

  @@index([driverId, date])
}

model DeliveryItem {
  id                 String  @id @default(cuid())
  deliveryScheduleId String
  productId          String
  quantity           Float
  reference          String?

  deliverySchedule   DeliverySchedule @relation(fields: [deliveryScheduleId], references: [id])
  product            Product @relation(fields: [productId], references: [id])
}

model Appointment {
  id                  String   @id @default(cuid())
  deliveryScheduleId  String
  destinationAddress  String
  scheduledTime       DateTime
  recipientContact    String?
  status              String   @default("scheduled") // scheduled|needs_reschedule|completed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  deliverySchedule    DeliverySchedule @relation(fields: [deliveryScheduleId], references: [id])
}

model TrackingPosition {
  id                 String   @id @default(cuid())
  deliveryScheduleId String
  latitude           Float
  longitude          Float
  timestamp          DateTime @default(now())

  deliverySchedule   DeliverySchedule @relation(fields: [deliveryScheduleId], references: [id])

  @@index([deliveryScheduleId, timestamp])
}

model ProofOfDelivery {
  id                 String   @id @default(cuid())
  deliveryScheduleId String   @unique
  recipientName      String
  signatureUrl       String?
  receivedAt         DateTime @default(now())
  createdAt          DateTime @default(now())

  deliverySchedule   DeliverySchedule @relation(fields: [deliveryScheduleId], references: [id])
}

// ============ LEGALITAS & GOV ============

model CooperativeProfile {
  id                   String   @id @default(cuid())
  cooperativeId        String   @unique
  name                 String
  address              String?
  NIB                  String?  @unique
  SKAHU                String?  @unique
  legalStatus          String?
  modalSimpananPokok   Float?
  modalSimpananWajib   Float?
  status               String   @default("draft") // draft|verified
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  cooperative          Cooperative @relation(fields: [cooperativeId], references: [id])
}

model LegalDocument {
  id                   String   @id @default(cuid())
  cooperativeId        String
  type                 String   // akta|SKAHU|NPWP|berita_acara|NIB
  fileUrl              String?
  verificationStatus   String   @default("unverified") // unverified|pending|verified|rejected
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  cooperative          Cooperative @relation(fields: [cooperativeId], references: [id])

  @@index([cooperativeId, type])
}

model VillagePotential {
  id            String   @id @default(cuid())
  cooperativeId String
  commodity     String
  areaSize      Float?
  volume        Float?
  laborCount    Int?
  estimatedValue Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
}

model Outlet {
  id            String    @id @default(cuid())
  cooperativeId String
  name          String
  location      String?
  status        String    @default("active") // active|inactive
  photo         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])

  @@index([cooperativeId, deletedAt])
}

model FinancingRequest {
  id            String    @id @default(cuid())
  cooperativeId String
  type          String    // bank_account|business_proposal|financing
  status        String    @default("draft") // draft|submitted|in_review|approved|rejected
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
}

model ExternalVerification {
  id                String    @id @default(cuid())
  cooperativeId     String
  type              String    // dukcapil_nik|humham_npak|pajak_djp|lahan_agrinas
  status            String    @default("pending") // pending|verified|rejected
  verifiedAt        DateTime?
  referenceResponse Json?
  createdAt         DateTime  @default(now())

  @@index([cooperativeId, type])
}

model Article {
  id           String    @id @default(cuid())
  cooperativeId String
  title        String
  content      String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
}

// ============ CROSS-CUTTING ============

model Outbox {
  id              String   @id @default(cuid())
  deviceId        String
  entityType      String
  operationType   String   // create|update|delete
  clientId        String   // ULID
  payload         Json
  idempotencyKey  String   @unique
  status          String   @default("pending") // pending|sent|synced|rejected|conflict
  attemptCount    Int      @default(0)
  lastError       String?
  createdAt       DateTime @default(now())

  @@index([deviceId, status])
}

model IdempotencyLedger {
  idempotencyKey String   @id
  processedAt    DateTime @default(now())
  resultStatus  String
}

model ConflictCase {
  id           String    @id @default(cuid())
  conflictType String    // oversell|vehicle_overlap|opname_variance
  entityRefs   Json
  status       String    @default("open") // open|resolved
  resolution   String?
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  resolvedByUser User? @relation("ResolvedBy", fields: [resolvedBy], references: [id])
}

model Notification {
  id            String    @id @default(cuid())
  cooperativeId String?
  recipientRole String?
  userId        String?
  type          String    // info|warning|error|success
  payload       Json
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  cooperative  Cooperative? @relation(fields: [cooperativeId], references: [id])
  user         User? @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String
  actorRole   String?
  entityType  String
  entityId    String
  action      String   // create|update|delete
  beforeValue Json?
  afterValue  Json?
  timestamp   DateTime @default(now())

  actor       User @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
}

model RuleSet {
  id        String   @id @default(cuid())
  ruleId    String
  condition Json
  action    Json
  version   Int      @default(1)
  module    String?
  createdAt DateTime @default(now())

  @@unique([ruleId, version])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}
